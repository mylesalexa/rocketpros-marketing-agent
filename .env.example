# Anthropic — Article generation
ANTHROPIC_API_KEY=sk-ant-...

# Brave Search — Topic research
BRAVE_API_KEY=BSA...

# OpenAI — DALL-E 3 hero images
OPENAI_API_KEY=sk-...

# Resend — Daily email digest
RESEND_API_KEY=re_...

# Email config
ADMIN_EMAIL=myles@rocketpros.app
EMAIL_FROM=agent@rocketpros.app

# Site URL (used in LinkedIn posts + TypeScript file comments)
SITE_URL=https://rocketpros.app

# How many articles to generate per daily run (default: 2)
ARTICLES_PER_RUN=2

# Dry run mode — set to "true" to skip email send and write to output/ only
DRY_RUN=false

# GitHub — for one-click publishing to rprosite-main
# Create a Personal Access Token at github.com/settings/tokens
# Scopes needed: repo (read + write contents)
GITHUB_TOKEN=github_pat_...
GITHUB_REPO=mylesalexa/rprosite-main
GITHUB_BRANCH=main

# Dashboard login (HTTP Basic Auth)
DASHBOARD_USER=myles
DASHBOARD_PASSWORD=choose-a-strong-password-here
